generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SurveyToken {
  id          String          @id @default(cuid())
  token       String          @unique
  teacherName String
  school      String
  grade       String
  sentTo      String
  sentVia     String
  completed   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  completedAt DateTime?
  responses   ChildResponse[]
}

model ChildResponse {
  id        String      @id @default(cuid())
  token     SurveyToken @relation(fields: [tokenId], references: [id])
  tokenId   String
  childIndex Int
  childName  String?
  gender    String
  age       String
  answers   Json
  createdAt DateTime    @default(now())
}
